# Allow Command Prefixes
prefix_rule(pattern=['pnpm', 'lint'])
prefix_rule(pattern=['pnpm', 'lint:eslint'])
prefix_rule(pattern=['pnpm', 'lint:svelte'])
prefix_rule(pattern=['pnpm', 'fmt'])
prefix_rule(pattern=['pnpm', 'fmt:fix'])
prefix_rule(pattern=['pnpm', 'build'])
prefix_rule(pattern=['git', 'diff'])
prefix_rule(pattern=['git', 'show'])
prefix_rule(pattern=['git', 'status'])
prefix_rule(pattern=['git', 'log'])
prefix_rule(pattern=['git', 'rev-parse'])
prefix_rule(pattern=['git', 'branch'])
prefix_rule(pattern=['gh', 'issue', 'view'])
prefix_rule(pattern=['gh', 'pr', 'view'])
prefix_rule(pattern=['gh', 'release', 'view'])
prefix_rule(pattern=['source', 'scripts/test-playwright.sh'])
prefix_rule(pattern=['bash', '.agents/skills/debug-local-o2/scripts/list-streams.sh'])
prefix_rule(pattern=['bash', '.agents/skills/debug-local-o2/scripts/recent-logs.sh'])
prefix_rule(pattern=['bash', '.agents/skills/debug-local-o2/scripts/recent-traces.sh'])
prefix_rule(pattern=['bash', '.agents/skills/debug-local-o2/scripts/search-by-route.sh'])
prefix_rule(pattern=['bash', '.agents/skills/debug-local-o2/scripts/search-by-trace.sh'])
prefix_rule(pattern=['bash', '.agents/skills/debug-local-o2/scripts/search-errors.sh'])
prefix_rule(pattern=['bash', '.agents/skills/debug-local-o2/scripts/search-inngest.sh'])
prefix_rule(pattern=['bash', '.agents/skills/debug-local-o2/scripts/search-logs.sh'])
prefix_rule(pattern=['bash', '.agents/skills/debug-local-o2/scripts/trace-spans.sh'])

# Prompt-Required Command Prefixes
prefix_rule(pattern=['docker', 'compose', 'exec', 'postgres', 'psql'], decision='prompt')
prefix_rule(pattern=['gh', 'pr', 'create'], decision='prompt')
prefix_rule(pattern=['pnpm', 'db:generate'], decision='prompt')
prefix_rule(pattern=['pnpm', 'db:migrate'], decision='prompt')
prefix_rule(pattern=['pnpm', 'docker:dev'], decision='prompt')
prefix_rule(pattern=['pnpm', 'docker:prod'], decision='prompt')
prefix_rule(pattern=['pnpm', 'docker:app'], decision='prompt')
prefix_rule(pattern=['pnpm', 'install:playwright'], decision='prompt')

# Forbidden Command Prefixes
prefix_rule(pattern=['bun'], decision='forbidden')
prefix_rule(pattern=['bunx'], decision='forbidden')
prefix_rule(pattern=['npm'], decision='forbidden')
prefix_rule(pattern=['npx'], decision='forbidden')
prefix_rule(pattern=['pnpx'], decision='forbidden')
prefix_rule(pattern=['yarn'], decision='forbidden')
prefix_rule(pattern=['pnpm', 'dlx'], decision='forbidden')
prefix_rule(pattern=['pnpm', 'exec'], decision='forbidden')
prefix_rule(pattern=['pnpm', 'run'], decision='forbidden')
prefix_rule(pattern=['pnpm', 'dev'], decision='forbidden')
prefix_rule(pattern=['pnpm', 'preview'], decision='forbidden')
prefix_rule(pattern=['pnpm', 'db:studio'], decision='forbidden')
prefix_rule(pattern=['pnpm', 'test:playwright'], decision='forbidden')
prefix_rule(pattern=['nu', 'scripts/test-playwright.nu'], decision='forbidden')
prefix_rule(pattern=['cat', '.env'], decision='forbidden')
prefix_rule(pattern=['cat', '.env.local'], decision='forbidden')
prefix_rule(pattern=['cat', '.env.development'], decision='forbidden')
prefix_rule(pattern=['cat', '.env.production'], decision='forbidden')
prefix_rule(pattern=['cat', '.env.test'], decision='forbidden')
