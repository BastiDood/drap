# Whitelist mode: recursively exclude everything, then selectively re-include.
**

# Package Managers
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml

# Vite + SvelteKit
!svelte.config.js
!vite.config.js
!tsconfig.json

# Application Source Code + Assets
!src/
!src/**
!static/
!static/**

# Documentation
src/**/*.md
