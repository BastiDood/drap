# `pnpm dev` => 5173
# `pnpm preview` => 4173
PUBLIC_ORIGIN='http://localhost:5173'
ORIGIN='http://localhost:5173'

# Required external values. Leave blank and fill them locally.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Generate from `pnpm random:bytes -- 32`. Used in AES-256-GCM encryption of sensitive OAuth tokens.
DRAP_ENCRYPTION_KEY=

# Leave unset to allow all email domains through the login page.
# DRAP_ASSERT_DOMAIN=up.edu.ph

# Leave unset unless you intentionally want real email delivery.
# DRAP_ENABLE_EMAILS=1

# Enables dev mode for Inngest, which disables cryptographic verification of events and webhooks.
INNGEST_DEV='http://localhost:8288'
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# Local PostgreSQL defaults.
POSTGRES_URL='postgresql://postgres:password@localhost'

# Local RustFS / S3 defaults.
S3_ENDPOINT='http://localhost:9000'
S3_REGION='us-east-1'
S3_ACCESS_KEY='drap'
S3_SECRET_KEY='password'

# Optional local OpenTelemetry export to OpenObserve.
OTEL_EXPORTER_OTLP_ENDPOINT='http://localhost:5080/api/default'
OTEL_EXPORTER_OTLP_HEADERS='Authorization=Basic%20YWRtaW5AZXhhbXBsZS5jb206cGFzc3dvcmQ%3D'
