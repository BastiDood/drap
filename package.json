{
  "name": "drap",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "encryption:generate": "node ./scripts/generate-encryption-key.js",
    "fmt": "prettier . --experimental-cli --check --cache-location .prettiercache",
    "fmt:fix": "prettier . --experimental-cli --write --cache-location .prettiercache",
    "lint": "pnpm run --workspace-root --parallel /^lint:/",
    "lint:svelte": "svelte-check --fail-on-warnings",
    "lint:eslint": "eslint --cache --concurrency auto",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "docker:dev": "docker compose --file compose.yaml --file compose.dev.yaml up --detach --wait",
    "docker:ci": "docker compose --file compose.yaml --file compose.dev.yaml --file compose.ci.yaml up --detach --wait",
    "docker:prod": "docker compose --file compose.yaml --file compose.prod.yaml up --detach --wait",
    "docker:app": "docker compose --file compose.yaml --file compose.prod.yaml --file compose.app.yaml up --detach --wait",
    "docker:down": "docker compose down --remove-orphans",
    "install:playwright": "playwright install chromium",
    "test:unit": "vitest",
    "test:playwright": "playwright test",
    "ui": "shadcn-svelte add --yes"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^0.577.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/instrumentation-pg": "^0.65.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@sveltejs/kit": "^2.55.0",
    "@tanstack/svelte-query": "^6.1.3",
    "better-svelte-email": "^1.4.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "decode-formdata": "^0.9.0",
    "devalue": "^5.6.4",
    "drizzle-orm": "^0.45.1",
    "email-addresses": "^5.0.0",
    "http-parser-js": "^0.5.10",
    "http-raw-request": "^2.0.2",
    "inngest": "^4.0.4",
    "itertools": "^2.6.0",
    "jose": "^6.2.2",
    "mimetext": "^3.0.28",
    "mode-watcher": "^1.1.0",
    "multipart-ts": "^1.4.1",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "runed": "^0.37.1",
    "svelte": "^5.54.0",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@bastidood/eslint-plugin-imsort": "^0.12.0",
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.58.1",
    "@html-eslint/eslint-plugin-svelte": "^0.58.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-node": "^5.5.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/table-core": "^8.21.3",
    "@types/node": "^24.12.0",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn-svelte": "^1.2.1",
    "svelte-check": "^4.4.5",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.57.1",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
