{
  "name": "drap",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "random:bytes": "node ./src/scripts/generate-random-bytes.js",
    "fmt": "prettier . --experimental-cli --check --cache-location .prettiercache",
    "fmt:fix": "prettier . --experimental-cli --write --cache-location .prettiercache",
    "lint": "pnpm run --workspace-root --parallel /^lint:/",
    "lint:svelte": "svelte-check --fail-on-warnings",
    "lint:eslint": "eslint --cache --concurrency auto",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "docker:dev": "docker compose --file compose.yaml --file compose.dev.yaml up --wait",
    "docker:dev:ci": "docker compose --file compose.yaml --file compose.dev.yaml --file compose.dev.ci.yaml up --wait",
    "docker:prod": "docker compose --file compose.yaml --file compose.prod.yaml up --wait",
    "docker:prod:app": "docker compose --file compose.yaml --file compose.prod.yaml --file compose.prod.app.yaml up --wait --build",
    "docker:prod:app:tls": "docker compose --file compose.yaml --file compose.prod.yaml --file compose.prod.app.yaml --file compose.prod.app.tls.yaml up --wait",
    "docker:dev:setup:bucket": "docker compose --file compose.yaml --file compose.dev.yaml --profile setup run --rm setup-bucket",
    "docker:prod:setup:bucket": "docker compose --file compose.yaml --file compose.prod.yaml --file compose.prod.app.yaml --profile setup run --rm setup-bucket",
    "docker:down": "docker compose down --remove-orphans",
    "install:playwright": "playwright install chromium",
    "test:unit": "vitest",
    "test:playwright": "playwright test",
    "ui": "shadcn-svelte add --yes"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@better-svelte-email/components": "^2.0.0",
    "@better-svelte-email/server": "^2.0.0",
    "@icons-pack/svelte-simple-icons": "^7.2.0",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.14.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/instrumentation-aws-sdk": "^0.72.0",
    "@opentelemetry/instrumentation-http": "^0.217.0",
    "@opentelemetry/instrumentation-pg": "^0.69.0",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@sveltejs/kit": "^2.59.1",
    "@tanstack/svelte-query": "^6.1.28",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-format": "^3.1.2",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "date-fns": "^4.1.0",
    "decode-formdata": "^0.9.0",
    "devalue": "^5.8.0",
    "drizzle-orm": "^0.45.2",
    "email-addresses": "^5.0.0",
    "get-stream": "^9.0.1",
    "http-parser-js": "^0.5.10",
    "http-raw-request": "^2.0.2",
    "inngest": "^4.3.0",
    "itertools": "^2.6.0",
    "jose": "^6.2.3",
    "layerchart": "2.0.0-next.62",
    "mime-types": "^3.0.2",
    "mimetext": "^3.0.28",
    "mode-watcher": "^1.1.0",
    "multipart-ts": "^1.4.2",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "runed": "^0.37.1",
    "svelte": "^5.55.5",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tldts": "^7.0.30",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@bastidood/eslint-plugin-imsort": "^0.12.0",
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.60.0",
    "@html-eslint/eslint-plugin-svelte": "^0.60.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.217.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/table-core": "^8.21.3",
    "@types/d3-array": "^3.2.2",
    "@types/d3-format": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.12.3",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^16.5.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn-svelte": "^1.2.7",
    "svelte-check": "^4.4.8",
    "svelte-eslint-parser": "^1.6.1",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.59.2",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
